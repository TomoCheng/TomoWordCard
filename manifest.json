{
  "manifest_version": 3,
  "name": "TomoWordCard",
  "version": "1.1",
  "description": "A simple Chrome extension for saving words to a word list.",
  "permissions": [
    "storage",
    "contextMenus",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}